{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Back Orchestrator",
  "version": "0.1.0",
  "identifier": "com.local.backorchestrator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Back Orchestrator",
        "width": 1600,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
